# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Telegram push (today's picks + yesterday's accuracy) ---
# 1. Create a bot via @BotFather, copy the token here.
# 2. DM your bot once, then visit
#    https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email (optional; Telegram alone is enough) ---
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# --- Optional overrides ---
# If the openfootball 2026 feed path differs, set it here.
# OPENFOOTBALL_URL=
# PREDICTIONS_PATH=data/predictions.jsonl
# WEB_PORT=8000
